#include <WiFi.h>
#include <ThingerESP32.h>

/* ========= THINGER.IO ========= */
#define USERNAME "Carlinhox_23"
#define DEVICE_ID "carlinhox_23"
#define DEVICE_CREDENTIAL "123456"

/* ========= WIFI ========= */
#define SSID "_HIRALDA_"
#define SSID_PASSWORD "**2004##25__"

/* ========= PINES ========= */
#define RELE 2
#define BUTTON 25

ThingerESP32 thing(USERNAME, DEVICE_ID, DEVICE_CREDENTIAL);

bool estadoRele = false;
bool lastButtonState = HIGH;

void setup() {
  Serial.begin(115200);
  delay(1000);

  pinMode(RELE, OUTPUT);
  pinMode(BUTTON, INPUT_PULLUP);

  digitalWrite(RELE, LOW);

  thing.add_wifi(SSID, SSID_PASSWORD);

  // Control desde Thinger
  thing["RELE"] << [](pson& in){
    if(in.is_empty()) {
      in = estadoRele;
    }
    else{
      estadoRele = in;
      digitalWrite(RELE, estadoRele);
    }
  };

  Serial.println("ESP32 iniciado. Revisa Thinger.io (ONLINE).");
}

void loop() {

  // --------- CONTROL PULSANTE ---------
  bool buttonState = digitalRead(BUTTON);

  if (buttonState == LOW && lastButtonState == HIGH) {
    estadoRele = !estadoRele;           // Cambia estado
    digitalWrite(RELE, estadoRele);
    Serial.println("Cambio por pulsante");
    delay(200); // anti-rebote simple
  }

  lastButtonState = buttonState;

  thing.handle();
}